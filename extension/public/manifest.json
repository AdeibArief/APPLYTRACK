{
  "manifest_version": 3,
  "name": "ApplyTrack",
  "version": "1.0.0",
  "description": "Track your job applications",
  "action": {
    "default_popup": "index.html"
  },
  "permissions": [
    "tabs",
    "activeTab",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  }
}