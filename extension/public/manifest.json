{
  "manifest_version": 3,
  "name": "ApplyTrack",
  "version": "1.0.0",
  "description": "Track your job applications",
  "action": {
    "default_popup": "index.html"
  },
  "permissions": [
    "tabs",
    "activeTab",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://www.indeed.com/*",
    "https://www.foundit.in/*",
    "https://wellfound.com/*",
    "https://in.indeed.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  }
}